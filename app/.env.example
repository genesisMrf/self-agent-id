# Deployed SelfAgentRegistry contract address (MUST be lowercase)
NEXT_PUBLIC_SELF_ENDPOINT=0x0000000000000000000000000000000000000000

NEXT_PUBLIC_SELF_APP_NAME="Self Agent ID"
NEXT_PUBLIC_SELF_SCOPE_SEED="self-agent-id"

# RPC for reading contract state
NEXT_PUBLIC_RPC_URL=https://forno.celo-sepolia.celo-testnet.org

# Mainnet contract addresses (Celo, chain 42220)
NEXT_PUBLIC_MAINNET_REGISTRY=
NEXT_PUBLIC_MAINNET_PROVIDER=
NEXT_PUBLIC_MAINNET_DEMO_VERIFIER=
NEXT_PUBLIC_MAINNET_AGENT_GATE=

# Relayer private key for on-chain demo verification meta-transactions
# NOTE: Server-side only — do NOT use NEXT_PUBLIC_ prefix
RELAYER_PRIVATE_KEY=

# Demo agent private key (for agent-to-agent demo)
DEMO_AGENT_PRIVATE_KEY=

# Demo service endpoints (Cloud Functions)
NEXT_PUBLIC_DEMO_SERVICE_URL=
NEXT_PUBLIC_DEMO_AGENT_URL=

# Account Abstraction (Smart Wallet mode)
# Get a Pimlico API key at https://dashboard.pimlico.io
# NOTE: Server-side only — do NOT use NEXT_PUBLIC_ prefix (key is proxied via /api/aa/)
PIMLICO_API_KEY=
# Create a ZeroDev project at https://dashboard.zerodev.app (any chain — passkey server is chain-agnostic)
NEXT_PUBLIC_ZERODEV_PROJECT_ID=
